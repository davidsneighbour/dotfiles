# shellcheck shell=bash

# dnb_is_interactive - return success when the shell is considered interactive.
#
# Checks the `DNB_IS_INTERACTIVE` environment variable and returns 0
# when its value is "1", otherwise returns non‑zero.
#
# Usage:
#   if dnb_is_interactive; then
#     # interactive setup
#   fi
dnb_is_interactive() {
  [[ "${DNB_IS_INTERACTIVE:-0}" == "1" ]]
}
