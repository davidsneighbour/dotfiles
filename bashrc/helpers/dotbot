#!/bin/bash
################################################################################
# Dotbot wrapper script
#
# @see https://github.com/davidsneighbour/dotfiles
################################################################################

set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
REPO_ROOT="$(cd "$(dirname "${SCRIPT_PATH}")/../.." && pwd)"
CONFIGS_DIR="${REPO_ROOT}/configs/dotbot"
DEFAULT_CONFIG_FILE="config.yaml"

DOTBOT_DIR="${REPO_ROOT}/modules/dotbot"
DOTBOT_BIN="${DOTBOT_DIR}/bin/dotbot"

source_core_libs() {
  local base_path="${BASHRC_PATH:-${REPO_ROOT}/bashrc}"
  local core_dir="${base_path}/lib/00-core"
  local file=''

  for file in "${core_dir}"/*.bash; do
    [[ -f "${file}" && -r "${file}" ]] || continue
    # shellcheck disable=SC1090
    source "${file}"
  done
}

init_logging() {
  local log_dir="${HOME}/.logs/dotbot"
  __LOGFILE="${log_dir}/setup-log-$(date +%Y%m%d-%H%M%S).log"
  export __LOGFILE
}

print_help() {
  cat <<'HELP'
Usage:
  dotbot [CONFIG_NAME]
  dotbot --config CONFIG_NAME
  dotbot --list
  dotbot --help

Options:
  --config CONFIG_NAME   Run a specific config.
                         Supported forms are equivalent:
                           host-locutus
                           config.host-locutus.yaml
  --list                 Select and run a config from configs/dotbot via gum.
  -h, --help             Show this help.

Behavior:
  - Default (no args): runs configs/dotbot/config.yaml
  - Positional CONFIG_NAME is preferred over --config.
HELP
}

ensure_dotbot_ready() {
  if [[ -d "${DOTBOT_DIR}" ]]; then
    git -C "${REPO_ROOT}" submodule sync --quiet --recursive
    git -C "${REPO_ROOT}" submodule update --init --recursive "${DOTBOT_DIR#"${REPO_ROOT}"/}" >/dev/null 2>&1
  fi

  if [[ ! -x "${DOTBOT_BIN}" ]]; then
    dnb_error "Dotbot binary not found or not executable at '${DOTBOT_BIN}'."
    exit 1
  fi
}

normalize_config_to_filename() {
  local raw_config_name="${1}"

  if [[ "${raw_config_name}" == "${DEFAULT_CONFIG_FILE}" || "${raw_config_name}" == config.*.yaml ]]; then
    printf '%s\n' "${raw_config_name}"
    return 0
  fi

  printf 'config.%s.yaml\n' "${raw_config_name}"
}

resolve_config_path() {
  local raw_config_name="${1}"
  local filename

  if [[ -z "${raw_config_name}" ]]; then
    filename="${DEFAULT_CONFIG_FILE}"
  else
    filename="$(normalize_config_to_filename "${raw_config_name}")"
  fi

  printf '%s/%s\n' "${CONFIGS_DIR}" "${filename}"
}

run_dotbot_with_config() {
  local config_path="${1}"
  local sanitized_config

  if [[ ! -f "${config_path}" ]]; then
    dnb_error "Config file not found: ${config_path}"
    print_help
    exit 1
  fi

  ensure_dotbot_ready

  sanitized_config="$(mktemp)"
  trap 'rm -f "${sanitized_config}"' RETURN

  grep -v -E '^- description:[[:space:]]*' "${config_path}" >"${sanitized_config}"

  export HOSTNAME
  HOSTNAME="$(hostname)"

  dnb_log info "Running Dotbot with config: ${config_path}"

  cd "${REPO_ROOT}"
  "${DOTBOT_BIN}" \
    --base-directory "${REPO_ROOT}" \
    --config-file "${sanitized_config}" \
    --force-color \
    --exit-on-failure
}

pick_config_with_gum() {
  if ! command -v gum >/dev/null 2>&1; then
    dnb_error "--list requires 'gum' (https://github.com/charmbracelet/gum)."
    exit 1
  fi

  local config_files=()
  local file

  shopt -s nullglob
  for file in "${CONFIGS_DIR}"/config.*.yaml; do
    config_files+=("$(basename "${file}")")
  done
  shopt -u nullglob

  if [[ "${#config_files[@]}" -eq 0 ]]; then
    dnb_error "No selectable config files found in ${CONFIGS_DIR}."
    exit 1
  fi

  mapfile -t config_files < <(printf '%s\n' "${config_files[@]}" | sort)

  local config_names=()
  local config_file
  for config_file in "${config_files[@]}"; do
    config_names+=("${config_file#config.}")
    config_names[${#config_names[@]}-1]="${config_names[${#config_names[@]}-1]%.yaml}"
  done

  gum choose --header "Select Dotbot config to run" "${config_names[@]}"
}

main() {
  source_core_libs
  init_logging

  local list_mode=0
  local config_arg=''
  local positional_config=''

  while (($#)); do
    case "$1" in
    --config)
      config_arg="${2-}"
      if [[ -z "${config_arg}" ]]; then
        dnb_error "--config requires a value."
        print_help
        exit 2
      fi
      shift 2
      ;;
    --list)
      list_mode=1
      shift
      ;;
    -h | --help)
      print_help
      exit 0
      ;;
    --*)
      dnb_error "Unknown option '$1'."
      print_help
      exit 2
      ;;
    *)
      if [[ -n "${positional_config}" ]]; then
        dnb_error "Only one config name is supported."
        print_help
        exit 2
      fi
      positional_config="$1"
      shift
      ;;
    esac
  done

  local target_config_path=''

  if [[ "${list_mode}" -eq 1 ]]; then
    if [[ -n "${config_arg}" || -n "${positional_config}" ]]; then
      dnb_error "--list cannot be combined with a config argument."
      print_help
      exit 2
    fi

    local selected_config=''
    selected_config="$(pick_config_with_gum)"
    target_config_path="$(resolve_config_path "${selected_config}")"
    run_dotbot_with_config "${target_config_path}"
    exit 0
  fi

  if [[ -n "${positional_config}" ]]; then
    target_config_path="$(resolve_config_path "${positional_config}")"
  elif [[ -n "${config_arg}" ]]; then
    target_config_path="$(resolve_config_path "${config_arg}")"
  else
    target_config_path="$(resolve_config_path '')"
  fi

  run_dotbot_with_config "${target_config_path}"
}

main "$@"
