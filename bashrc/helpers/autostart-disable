#!/usr/bin/bash
set -euo pipefail

# Lists symlinks in the host autostart directory and removes the selected one(s).
DIR_AUTOSTARTS="${HOME}/.dotfiles/configs/system/autostart"
DEST_HOST="${HOSTNAME:-unknown-host}"
PROMPT="Select symlink(s) to remove:"
TITLE_COLOR=$'\033[38;2;248;248;242m'
DESCRIPTION_COLOR=$'\033[38;2;112;140;169m'
COLOR_RESET=$'\033[0m'

get_desktop_entry_value() {
  local file_path="$1"
  local exact_key="$2"
  local localized_prefix="$3"
  local line=""
  local key=""
  local value=""
  local in_desktop_entry="false"

  while IFS= read -r line; do
    if [[ "${line}" == "[Desktop Entry]" ]]; then
      in_desktop_entry="true"
      continue
    fi

    if [[ "${in_desktop_entry}" != "true" ]]; then
      continue
    fi

    if [[ "${line}" =~ ^\[.*\]$ ]]; then
      break
    fi

    if [[ "${line}" != *=* ]]; then
      continue
    fi

    key="${line%%=*}"
    value="${line#*=}"

    if [[ "${key}" == "${exact_key}" ]]; then
      printf '%s\n' "${value}"
      return 0
    fi

    if [[ "${key}" =~ ^${localized_prefix}\[[^]]+\]$ ]]; then
      printf '%s\n' "${value}"
      return 0
    fi
  done < "${file_path}"

  return 1
}

build_select_line() {
  local index="$1"
  local title="$2"
  local description="$3"
  local line=""

  line="${index}) ${TITLE_COLOR}${title}${COLOR_RESET}"
  if [[ -n "${description}" ]]; then
    line="${line} ${DESCRIPTION_COLOR}${description}${COLOR_RESET}"
  fi

  printf '%s\n' "${line}"
}

print_help() {
  cat <<EOF
Usage: $(basename "${0}") [--host HOSTNAME] [--dir-autostarts DIR] [--prompt PROMPT]

Removes selected symlink(s) from: \${DIR_AUTOSTARTS}/<hostname>/

Options:
  --host HOSTNAME     Override destination hostname directory (default: ${DEST_HOST} (local host))
  --dir-autostarts D  Base autostarts dir (default: ${DIR_AUTOSTARTS})
  --prompt PROMPT     Prompt text (default: "${PROMPT}")
  --help              Display this help and exit
EOF
}

# Parse args
while (( "$#" )); do
  case "$1" in
    --host) DEST_HOST="${2:-}"; shift 2 ;;
    --dir-autostarts) DIR_AUTOSTARTS="${2:-}"; shift 2 ;;
    --prompt) PROMPT="${2:-}"; shift 2 ;;
    --help) print_help; exit 0 ;;
    *) echo "Error: Unknown option: $1" >&2; print_help >&2; exit 1 ;;
  esac
done

# Pre-flight
if ! command -v gum >/dev/null 2>&1; then
  echo "Error: gum is not installed or not in PATH." >&2
  exit 1
fi

dest_dir="${DIR_AUTOSTARTS%/}/${DEST_HOST}"
if [[ ! -d "${dest_dir}" ]]; then
  echo "Error: Host directory not found: '${dest_dir}'" >&2
  exit 1
fi

# Collect only symlinks in host dir
shopt -s nullglob
entries=( "${dest_dir}"/* )
shopt -u nullglob

symlinks=()
for p in "${entries[@]}"; do
  [[ -L "${p}" ]] && symlinks+=( "${p}" )
done

if (( ${#symlinks[@]} == 0 )); then
  echo "No symlinks found in: '${dest_dir}'" >&2
  exit 1
fi

# Build selection display lines
declare -A selection_by_index=()
selection_lines=()
selection_index=1
for p in "${symlinks[@]}"; do
  base_name="$(basename -- "${p}")"
  title="${base_name}"
  description=""
  desktop_source="${DIR_AUTOSTARTS%/}/available/${base_name}"

  if [[ -f "${desktop_source}" ]]; then
    if parsed_title="$(get_desktop_entry_value "${desktop_source}" "Name" "Name")"; then
      title="${parsed_title}"
    fi

    if parsed_description="$(get_desktop_entry_value "${desktop_source}" "Comment" "Comment")"; then
      description="${parsed_description}"
    fi
  fi

  selection_by_index["${selection_index}"]="${base_name}"
  selection_lines+=( "$(build_select_line "${selection_index}" "${title}" "${description}")" )
  ((selection_index++))
done

# gum filter selection
if ! selected_out=$(printf '%b\n' "${selection_lines[@]}" | gum filter --placeholder "${PROMPT}" --no-limit); then
  echo "No selection made." >&2
  exit 1
fi

# Normalize to array
selections=()
while IFS= read -r line; do
  [[ -z "${line}" ]] && continue
  selection_id="${line%%)*}"
  if [[ "${selection_id}" =~ ^[0-9]+$ ]] && [[ -n "${selection_by_index[${selection_id}]:-}" ]]; then
    selections+=( "${selection_by_index[${selection_id}]}" )
  fi
done <<< "${selected_out}"

# Remove each chosen symlink safely
for sel in "${selections[@]}"; do
  target_path="${dest_dir}/${sel}"
  if [[ -L "${target_path}" ]]; then
    rm -f -- "${target_path}"
    printf 'Removed symlink: %s\n' "${target_path}"
  else
    printf 'Skipped non-symlink: %s\n' "${target_path}" >&2
  fi
done
