#!/bin/bash
# shellcheck shell=bash
# dnb-dotfiles v3002.20.0

dotfiles() {
  # Manage and open the user's dotfiles repository.
  #
  # Usage:
  #   dotfiles [--help]
  #   dotfiles [--version]
  #   dotfiles [--next]
  #   dotfiles [--status]
  #
  # Behaviour:
  #   No option:
  #     Changes into ${HOME}/.dotfiles and opens VS Code there.
  #
  #   --version:
  #     Reads ${HOME}/.dotfiles/package.json and prints the current package version.
  #
  #   --next:
  #     Reads ${HOME}/.dotfiles/package.json, increments the minor version, resets
  #     the patch version to 0, and prints the resulting version.
  #
  #   --status:
  #     Runs git status inside ${HOME}/.dotfiles.
  #
  # Requirements:
  #   * bash
  #   * node
  #   * git
  #   * code, for the default no-option behaviour
  #
  # Examples:
  #   dotfiles
  #   dotfiles --version
  #   dotfiles --next
  #   dotfiles --status

  local dotfiles_dir
  dotfiles_dir="${HOME}/.dotfiles"

  local package_file
  package_file="${dotfiles_dir}/package.json"

  local command_name
  command_name="${FUNCNAME[0]}"

  dotfiles_print_help() {
    cat <<EOF
Usage: ${command_name} [--help|--version|--next|--status]

Manage the dotfiles repository at:

  ${dotfiles_dir}

Options:
  --help      Show this help message.
  --version   Print the version from ${package_file}.
  --next      Print the next minor version based on ${package_file}.
  --status    Run git status inside ${dotfiles_dir}.

Default behaviour:
  With no option, cd into ${dotfiles_dir} and run:

    code .

Examples:
  ${command_name}
  ${command_name} --version
  ${command_name} --next
  ${command_name} --status
EOF
  }

  dotfiles_require_directory() {
    if [[ ! -d "${dotfiles_dir}" ]]; then
      printf '[error] Dotfiles directory does not exist: %s\n' "${dotfiles_dir}" >&2
      dotfiles_print_help >&2
      return 1
    fi
  }

  dotfiles_require_package_file() {
    if [[ ! -f "${package_file}" ]]; then
      printf '[error] package.json does not exist: %s\n' "${package_file}" >&2
      dotfiles_print_help >&2
      return 1
    fi
  }

  dotfiles_get_version() {
    dotfiles_require_package_file || return 1

    node --input-type=module -e '
      import { readFileSync } from "node:fs";

      const packagePath = process.argv[1];

      try {
        const packageJson = JSON.parse(readFileSync(packagePath, "utf8"));

        if (typeof packageJson.version !== "string" || packageJson.version.trim() === "") {
          console.error(`[error] Missing or invalid "version" field in ${packagePath}`);
          process.exit(1);
        }

        console.log(packageJson.version);
      } catch (error) {
        const message = error instanceof Error ? error.message : String(error);
        console.error(`[error] Failed to read package version: ${message}`);
        process.exit(1);
      }
    ' "${package_file}"
  }

  dotfiles_get_next_version() {
    dotfiles_require_package_file || return 1

    node --input-type=module -e '
      import { readFileSync } from "node:fs";

      const packagePath = process.argv[1];

      try {
        const packageJson = JSON.parse(readFileSync(packagePath, "utf8"));
        const version = packageJson.version;

        if (typeof version !== "string" || version.trim() === "") {
          console.error(`[error] Missing or invalid "version" field in ${packagePath}`);
          process.exit(1);
        }

        const match = /^(?<major>0|[1-9]\d*)\.(?<minor>0|[1-9]\d*)\.(?<patch>0|[1-9]\d*)$/.exec(version);

        if (match?.groups === undefined) {
          console.error(`[error] Version must use plain semver format MAJOR.MINOR.PATCH, got: ${version}`);
          process.exit(1);
        }

        const major = Number.parseInt(match.groups.major, 10);
        const minor = Number.parseInt(match.groups.minor, 10) + 1;

        console.log(`${major}.${minor}.0`);
      } catch (error) {
        const message = error instanceof Error ? error.message : String(error);
        console.error(`[error] Failed to calculate next version: ${message}`);
        process.exit(1);
      }
    ' "${package_file}"
  }

  dotfiles_open_repository() {
    dotfiles_require_directory || return 1

    cd "${dotfiles_dir}" || {
      printf '[error] Failed to cd into: %s\n' "${dotfiles_dir}" >&2
      return 1
    }

    code .
  }

  dotfiles_git_status() {
    dotfiles_require_directory || return 1

    git -C "${dotfiles_dir}" status
  }

  case "${1:-}" in
  "")
    dotfiles_open_repository
    ;;
  --help | -h)
    dotfiles_print_help
    ;;
  --version)
    dotfiles_get_version
    ;;
  --next)
    dotfiles_get_next_version
    ;;
  --status)
    dotfiles_git_status
    ;;
  *)
    printf '[error] Unknown option: %s\n' "${1}" >&2
    dotfiles_print_help >&2
    return 1
    ;;
  esac
}
