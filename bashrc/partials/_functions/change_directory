#!/bin/bash
# shellcheck shell=bash
# dnb-dotfiles v3002.20.0

# Changes directory and then:
#   - switches Node.js via nvm when the effective .nvmrc changes
#   - shows git status when the repository has local changes

_cd_effective_nvmrc() {
  local dir="${PWD}"

  while [[ "${dir}" != "/" ]]; do
    if [[ -f "${dir}/.nvmrc" ]]; then
      printf '%s\n' "${dir}/.nvmrc"
      return 0
    fi

    dir="$(dirname "${dir}")"
  done

  if [[ -f "${HOME}/.nvmrc" ]]; then
    printf '%s\n' "${HOME}/.nvmrc"
    return 0
  fi

  return 1
}

_cd_maybe_use_nvm() {
  command -v nvm >/dev/null 2>&1 || return 0

  local nvmrc
  nvmrc="$(_cd_effective_nvmrc)" || return 0

  local version
  version="$(<"${nvmrc}")"

  local state="${nvmrc}:${version}"

  if [[ "${state}" == "${_CD_LAST_NVM_STATE:-}" ]]; then
    return 0
  fi

  nvm use --silent >/dev/null 2>&1 || {
    printf '[cd] nvm use failed for %s\n' "${nvmrc}" >&2
    return 0
  }

  _CD_LAST_NVM_STATE="${state}"
}

_cd_maybe_show_git_status() {
  command -v git >/dev/null 2>&1 || return 0
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 0

  if [[ -n "$(git status --short 2>/dev/null)" ]]; then
    git status -sb
  fi
}

change_directory() {
  if [[ "${1:-}" == "--help" ]]; then
    cat <<EOF
Usage: cd [directory]

Changes directory and then:
  - switches Node.js via nvm when the effective .nvmrc changes
  - shows git status when the repository has local changes

The effective .nvmrc is the nearest .nvmrc above the current directory,
falling back to ${HOME}/.nvmrc if present.
EOF
    return 0
  fi

  builtin cd "$@" || return

  _cd_maybe_use_nvm
  _cd_maybe_show_git_status
}
