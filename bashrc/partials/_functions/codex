#!/bin/bash
# shellcheck shell=bash

codex-local() {
  # Help
  if [[ "${1:-}" == "--help" ]]; then
    cat <<EOF
Usage: $(basename "$0") [ARGS...]

Runs codex against a local or configured Ollama instance.

Environment:
  OLLAMA_HOST   Optional. Example: http://192.168.1.10:11434

Behaviour:
  - Uses OLLAMA_HOST if set
  - Falls back to http://localhost:11434
  - Verifies Ollama availability before execution
EOF
    return 0
  fi

  # Determine host
  local ollama_host="${OLLAMA_HOST:-http://localhost:11434}"
  local health_endpoint="${ollama_host%/}/v1/models"

  if [[ ! "${ollama_host}" =~ ^https?:// ]]; then
    echo "ERROR: OLLAMA_HOST must include scheme (http:// or https://)" >&2
    return 1
  fi

  # Check availability
  if ! curl -s --fail "${health_endpoint}" >/dev/null 2>&1; then
    echo "ERROR: Ollama not reachable at ${ollama_host}" >&2
    return 1
  fi

  # Execute
  codex --profile local-ollama "$@"
}
