#!/bin/bash

set -Eeuo pipefail

SCRIPT_NAME="$(basename "$0")"
LOG_DIR="${HOME}/.logs/workspaces"
LOG_FILE=""
VERBOSE="0"
OUTPUT_MODE="programs"
INCLUDE_STICKY="0"

usage() {
  cat <<EOF_USAGE
Usage:
  ${SCRIPT_NAME} [--workspace-full] [--full] [--workspace <N>] [--verbose]
  ${SCRIPT_NAME} --help

List windows by workspace using wmctrl.

Default output:
  Program names on the current workspace, one per line.

Options:
  --workspace-full     List every current-workspace window: workspace, window_id, program, title.
  --full               List every window on every workspace (sorted by workspace).
  --workspace <N>      Use a specific workspace number (1-based) instead of current.
  --include-sticky     Include sticky windows (desktop index -1).
  --verbose            Enable verbose logging. Also enabled when DNB_VERBOSE is set.
  --help               Show this help.

Examples:
  ${SCRIPT_NAME}
  ${SCRIPT_NAME} --workspace-full
  ${SCRIPT_NAME} --full
  ${SCRIPT_NAME} --workspace 3
EOF_USAGE
}

init_logging() {
  mkdir -p "${LOG_DIR}"
  LOG_FILE="${LOG_DIR}/setup-log-$(date +%Y%m%d-%H%M%S).log"
  : > "${LOG_FILE}"
}

log_line() {
  local level="$1"
  local message="$2"
  local timestamp

  timestamp="$(date '+%Y-%m-%d %H:%M:%S')"
  printf '[%s] [%s] %s\n' "${timestamp}" "${level}" "${message}" >> "${LOG_FILE}"

  if [[ "${level}" == "ERROR" || "${VERBOSE}" == "1" ]]; then
    printf '[%s] %s\n' "${level}" "${message}" >&2
  fi
}

die() {
  local message="$1"
  log_line "ERROR" "${message}"
  echo >&2
  usage >&2
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1
}

current_workspace_index() {
  wmctrl -d | awk '/\*/ { print $1 }'
}

workspace_window_rows() {
  wmctrl -lx | awk -v include_sticky="${INCLUDE_STICKY}" '
    {
      workspace = $2
      if (workspace == "-1" && include_sticky != "1") {
        next
      }

      window_id = $1
      wm_class = $4
      title = ""
      for (i = 5; i <= NF; i += 1) {
        title = title $i
        if (i < NF) {
          title = title " "
        }
      }

      split(wm_class, class_parts, ".")
      program = class_parts[length(class_parts)]
      if (program == "") {
        program = wm_class
      }

      printf "%s\t%s\t%s\t%s\n", workspace, window_id, program, title
    }
  '
}

render_programs_for_workspace() {
  local target_workspace="$1"
  workspace_window_rows | awk -F $'\t' -v ws="${target_workspace}" '$1 == ws { print $3 }' | awk '!seen[$0]++'
}

render_windows_for_workspace() {
  local target_workspace="$1"
  workspace_window_rows | awk -F $'\t' -v ws="${target_workspace}" '$1 == ws { printf "%s\t%s\t%s\t%s\n", $1, $2, $3, $4 }'
}

render_full() {
  workspace_window_rows | sort -t $'\t' -k1,1n -k3,3
}

main() {
  if [[ -n "${DNB_VERBOSE:-}" ]]; then
    VERBOSE="1"
  fi

  local workspace_override=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help)
        usage
        exit 0
        ;;
      --verbose)
        VERBOSE="1"
        shift
        ;;
      --workspace-full)
        OUTPUT_MODE="workspace-full"
                shift
        ;;
      --full)
        OUTPUT_MODE="full"
        shift
        ;;
      --workspace)
        shift
        [[ $# -gt 0 ]] || die "--workspace requires a value"
        workspace_override="$1"
        shift
        ;;
      --include-sticky)
        INCLUDE_STICKY="1"
        shift
        ;;
      *)
        echo "ERROR: Unknown option: $1" >&2
        echo >&2
        usage >&2
        exit 1
        ;;
    esac
  done

  init_logging

  need_cmd wmctrl || die "wmctrl is required. Install with: sudo apt install wmctrl"

  local target_workspace=""
  if [[ -n "${workspace_override}" ]]; then
    [[ "${workspace_override}" =~ ^[0-9]+$ ]] || die "--workspace must be a positive integer"
    [[ "${workspace_override}" -ge 1 ]] || die "--workspace must be >= 1"
    target_workspace="$((workspace_override - 1))"
  else
    target_workspace="$(current_workspace_index)"
  fi

  [[ -n "${target_workspace}" ]] || die "Could not determine target workspace"

  if [[ "${OUTPUT_MODE}" == "full" ]]; then
    log_line "INFO" "Rendering windows from all workspaces"
    render_full
    return 0
  fi

  if [[ "${OUTPUT_MODE}" == "workspace-full" ]]; then
    log_line "INFO" "Rendering window-level output for workspace ${target_workspace}"
    render_windows_for_workspace "${target_workspace}"
    return 0
  fi

  log_line "INFO" "Rendering program names for workspace ${target_workspace}"
  render_programs_for_workspace "${target_workspace}"
}

main "$@"
