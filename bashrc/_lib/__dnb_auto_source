# shellcheck shell=bash

# ---
# name: __dnb_auto_source
# summary: Load and source shell scripts from files or directories.
# description: |
#   Sources one or more files or every readable regular file inside
#   a provided directory. This is useful for loading completion
#   scripts, helper functions, or other shell snippets into the
#   current interactive shell session.
# usage: |
#   __dnb_auto_source "/path/to/dir"
#   __dnb_auto_source "/path/to/script.sh" "/another/path"
#   __dnb_auto_source "${ARRAY_OF_PATHS[@]}"
# parameters:
#   - name: PATHS...
#     type: path
#     required: true
#     description: One or more file or directory paths. If a path
#       is a directory, each readable regular file inside will be
#       sourced in arbitrary order.
# examples:
#   - "__dnb_auto_source ~/.bash_completion.d"
#   - "__dnb_auto_source /etc/bash_completion.d /home/user/.local/completions"
# notes: |
#   Files are sourced only if they are regular files and readable.
#   The function uses the shell builtin `source` so loaded code runs
#   in the current shell environment. Avoid sourcing untrusted
#   directories to prevent execution of arbitrary code.
# ---

__dnb_auto_source() {

  for ITEM in "$@"; do
    if [ -d "${ITEM}" ]; then
      for FILE in "${ITEM}"/*; do
        # shellcheck source=/dev/null
        [ -r "${FILE}" ] && [ -f "${FILE}" ] && source "${FILE}"
      done
    elif [ -r "${ITEM}" ] && [ -f "${ITEM}" ]; then
      # shellcheck source=/dev/null
      source "${ITEM}"
    fi
  done

}
