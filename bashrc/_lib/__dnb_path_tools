# Add a directory to PATH only if it is not already present.
# Intended for use in ~/.bashrc or sourced helper files.
#
# Features:
# - ignores empty input
# - ignores non-existing directories
# - avoids duplicates
# - optional prepend/append mode
# - supports --help
# - prints messages only when DNB_VERBOSE=1 or DNB_VERBOSE=true
#
# Examples:
#   path_add_if_missing --dir "${HOME}/.local/bin"
#   path_add_if_missing --dir "${HOME}/bin" --prepend
#   path_add_if_missing --help
path_add_if_missing() {
  local dir=""
  local mode="prepend"
  local verbose="false"

  if [[ "${DNB_VERBOSE:-}" == "1" || "${DNB_VERBOSE:-}" == "true" ]]; then
    verbose="true"
  fi

  _path_add_if_missing_help() {
    local cmd
    cmd="${FUNCNAME[1]}"

    cat <<EOF
Usage:
  ${cmd} --dir DIRECTORY [--append|--prepend]
  ${cmd} --help

Description:
  Adds DIRECTORY to PATH only if it is not already present.

Options:
  --dir DIRECTORY   Directory to add to PATH.
  --append          Add directory at the end of PATH.
  --prepend         Add directory at the beginning of PATH. Default.
  --help            Show this help text.

Behaviour:
  * If DIRECTORY is empty, the function returns without changes.
  * If DIRECTORY does not exist or is not a directory, the function returns without changes.
  * If DIRECTORY is already present in PATH, it is not added again.
  * Output is only shown when DNB_VERBOSE=1 or DNB_VERBOSE=true.

Examples:
  ${cmd} --dir "${HOME}/.local/bin"
  ${cmd} --dir "${HOME}/bin" --prepend
EOF
  }

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --dir)
      if [[ -n "${2:-}" ]]; then
        dir="$2"
        shift 2
        continue
      fi
      printf 'ERROR: --dir requires a value.\n' >&2
      _path_add_if_missing_help
      return 1
      ;;
    --append)
      mode="append"
      shift
      continue
      ;;
    --prepend)
      mode="prepend"
      shift
      continue
      ;;
    --help)
      _path_add_if_missing_help
      return 0
      ;;
    *)
      printf 'ERROR: Unknown option: %s\n' "$1" >&2
      _path_add_if_missing_help
      return 1
      ;;
    esac
  done

  if [[ -z "${dir}" ]]; then
    printf 'ERROR: --dir is required.\n' >&2
    _path_add_if_missing_help
    return 1
  fi

  if [[ ! -d "${dir}" ]]; then
    if [[ "${verbose}" == "true" ]]; then
      printf 'INFO: Not adding to PATH because directory does not exist: %s\n' "${dir}"
    fi
    return 0
  fi

  case ":${PATH}:" in
  *:"${dir}":*)
    if [[ "${verbose}" == "true" ]]; then
      printf 'INFO: Directory already in PATH: %s\n' "${dir}"
    fi
    return 0
    ;;
  esac

  if [[ "${mode}" == "prepend" ]]; then
    export PATH="${dir}:${PATH}"
    if [[ "${verbose}" == "true" ]]; then
      printf 'INFO: Prepended directory to PATH: %s\n' "${dir}"
    fi
  else
    export PATH="${PATH}:${dir}"
    if [[ "${verbose}" == "true" ]]; then
      printf 'INFO: Appended directory to PATH: %s\n' "${dir}"
    fi
  fi
}

