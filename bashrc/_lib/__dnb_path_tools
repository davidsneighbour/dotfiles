# Clean up PATH by:
# - removing duplicate directories
# - removing non-existing directories
# - preserving the first occurrence order
#
# Options:
#   --help   Show help.
#
# Environment:
#   DNB_VERBOSE=1|true   Print informational output.
path_sanitise() {
  local verbose="false"
  local path_entry=""
  local new_path=""
  local removed_duplicates=0
  local removed_missing=0
  local old_ifs="${IFS}"

  if [[ "${DNB_VERBOSE:-}" == "1" || "${DNB_VERBOSE:-}" == "true" ]]; then
    verbose="true"
  fi

  _path_sanitise_help() {
    cat <<EOF
Usage:
  ${FUNCNAME[1]} [--help]

Description:
  Remove duplicate and non-existing directories from PATH and re-export it.

Behaviour:
  * Keeps the first occurrence of each directory.
  * Removes entries that do not exist or are not directories.
  * Preserves original order of surviving entries.

Examples:
  ${FUNCNAME[1]}
  ${FUNCNAME[1]} --help
EOF
  }

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --help)
      _path_sanitise_help
      return 0
      ;;
    *)
      printf 'ERROR: Unknown option: %s\n' "$1" >&2
      _path_sanitise_help
      return 1
      ;;
    esac
  done

  IFS=':'
  for path_entry in ${PATH:-}; do
    if [[ -z "${path_entry}" ]]; then
      continue
    fi

    if [[ ! -d "${path_entry}" ]]; then
      removed_missing=$((removed_missing + 1))
      if [[ "${verbose}" == "true" ]]; then
        printf 'INFO: Removing non-existing PATH entry: %s\n' "${path_entry}"
      fi
      continue
    fi

    case ":${new_path}:" in
    *:"${path_entry}":*)
      removed_duplicates=$((removed_duplicates + 1))
      if [[ "${verbose}" == "true" ]]; then
        printf 'INFO: Removing duplicate PATH entry: %s\n' "${path_entry}"
      fi
      continue
      ;;
    esac

    if [[ -z "${new_path}" ]]; then
      new_path="${path_entry}"
    else
      new_path="${new_path}:${path_entry}"
    fi
  done
  IFS="${old_ifs}"

  export PATH="${new_path}"

  if [[ "${verbose}" == "true" ]]; then
    printf 'INFO: PATH sanitised. Removed duplicates: %s. Removed missing: %s.\n' \
      "${removed_duplicates}" "${removed_missing}"
  fi
}
