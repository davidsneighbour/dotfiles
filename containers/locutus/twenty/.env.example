# Twenty CRM version pin.
# Upstream compose file expects this variable named "TAG" (not TWENTY_TAG) — see README.md
# "Updating Twenty" for how to change it intentionally.
TAG=v2.23.2

# --- Database ---
PG_DATABASE_USER=postgres
# Generate with: openssl rand -hex 24
# Twenty builds PG_DATABASE_URL as an unescaped connection string, so avoid characters
# that are special in a URL (@ : / ? # % + etc.) — hex output is always safe.
PG_DATABASE_PASSWORD=replace_me_with_a_strong_password_without_special_characters
PG_DATABASE_NAME=default
#PG_DATABASE_HOST=db
#PG_DATABASE_PORT=5432

# --- Redis ---
#REDIS_URL=redis://redis:6379

# --- Server ---
SERVER_URL=http://localhost:3000

# --- Secrets ---
# Generate with: openssl rand -base64 32
# WARNING: losing ENCRYPTION_KEY permanently locks every secret stored in the database
# (OAuth tokens, integration credentials, TOTP secrets, etc.). Back this value up securely
# and never commit it.
ENCRYPTION_KEY=replace_me_with_a_random_string
#FALLBACK_ENCRYPTION_KEY= # only set during a key rotation, to the previous ENCRYPTION_KEY
#APP_SECRET= # legacy, only required for instances that pre-date ENCRYPTION_KEY

# --- Storage ---
STORAGE_TYPE=local

# --- Migrations / cron registration ---
# This setup runs one server + one worker; the server owns migrations and cron
# registration, so leave these blank/false here (the worker hardcodes them to "true").
DISABLE_DB_MIGRATIONS=
DISABLE_CRON_JOBS_REGISTRATION=

# --- Optional integrations (not configured in this initial installation) ---
#STORAGE_S3_REGION=
#STORAGE_S3_NAME=
#STORAGE_S3_ENDPOINT=
#STORAGE_S3_ACCESS_KEY_ID=
#STORAGE_S3_SECRET_ACCESS_KEY=
