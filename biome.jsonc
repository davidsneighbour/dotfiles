{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["./node_modules/@dnbhq/biome-config/config.json"],
  "files": {
    "includes": [
      "**",
      "!build",
      "!configs/fonts",
      "!coverage",
      "!configs/theme/DNB-Bibata",
      "!configs/theme/Dracula",
      "!configs/vscode",
      "!containers",
      "!configs/vscode/extensions/dnb-dotfiles-tools/node_modules",
      "!logs",
      "!modules/protected"
    ]
  }
}
