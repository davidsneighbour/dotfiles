{
  // https://code.visualstudio.com/api/references/theme-color
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#6272a4",
    "activityBar.background": "#6272a4",
    "activityBar.foreground": "#000000",
    "activityBar.inactiveForeground": "#99999999",
    "activityBarBadge.background": "#422c74",
    "activityBarBadge.foreground": "#999999",
    "commandCenter.border": "#999999",
    "sash.hoverBorder": "#2f7c47",
    "statusBar.background": "#6272a4",
    "statusBar.foreground": "#000000",
    "statusBarItem.hoverBackground": "#6272a4",
    "statusBarItem.remoteBackground": "#6272a4",
    "statusBarItem.remoteForeground": "#000000",
    "titleBar.activeBackground": "#6272a4",
    "titleBar.activeForeground": "#000000",
    "titleBar.inactiveBackground": "#6272a499",
    "titleBar.inactiveForeground": "#00000099",
    "editorIndentGuide.background1": "#00000001",
    "editorIndentGuide.activeBackground1": "#ff9900"
  },
  //"peacock.color": "#6272a4",
  "explorer.fileNesting.patterns": {
    "README.md": "SECURITY*, LICENSE*, CITATION.cff, OS_INSTALL_FIRST_STEPS.md, AGENTS.md",
    "package.json": ".lintstagedrc.*,.commitlintrc.*,.markdownlint.*,.npmrc.*,.nvmrc,.secretlint*,.shellcheck*,biome.*,.yamllint.*,.versionrc.*,eslint.*,jsconfig.*,tsconfig.*,link.config.*,package-lock.json, .fixpackrc, .editorconfig, .release-it.*",
    "actions.sh": "actions.toml"
  },
  "markdown.extension.toc.levels": "2..6",
  "deno.enable": false,
  // https://code.visualstudio.com/api/references/theme-color
  "cSpell.language": "en-GB",
  "cSpell.enabled": true,
  "cSpell.customDictionaries": {
    "dotfiles": {
      "name": "dotfiles",
      "path": "${workspaceFolder:dotfiles}/.vscode/cspell-dict-dotfiles.txt",
      "description": "Words used in this project",
      "addWords": true,
      "scope": "workspace"
    }
  },
  "cSpell.validateDirectives": true,
  "chat.tools.terminal.autoApprove": {
    "mkdir": true
  },
  "editor.allowVariableFontsInAccessibilityMode": false,
  "editor.codeLensFontFamily": "'Monaspace Krypton'",
  "editor.inlayHints.fontFamily": "'Monaspace Krypton'",
  "editor.fontFamily": "Monaspace Krypton Var, Fira Code, Monaco, monospace",
  "editor.fontSize": 15,
  "editor.fontVariations": "'wght' 250",
  "editor.fontLigatures": "'calt', 'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08', 'ss09', 'ss10', 'liga'",
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "comment",
        "settings": {
          "fontStyle": "italic"
        }
      },
      {
        "scope": "storage,entity,variable",
        "settings": {
          "fontStyle": ""
        }
      }
    ]
  },
  "terminal.integrated.fontFamily": "Monaspace Krypton Var, Fira Code, Monaco, monospace",
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.fontWeight": 150,
  "terminal.integrated.fontWeightBold": 400,
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.fontLigatures.featureSettings": "'calt' on, 'liga' on, 'ss01' on, 'ss02' on, 'ss03' on, 'ss04' on, 'ss05' on, 'ss06' on, 'ss07' on, 'ss08' on, 'ss09' on, 'ss10' on",
  "editor.defaultFormatter": "biomejs.biome",
  "[jsonnet]": {
    "editor.defaultFormatter": "Grafana.vscode-jsonnet"
  }
}