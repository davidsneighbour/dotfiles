{
  "[jsonnet]": {
    "editor.defaultFormatter": "Grafana.vscode-jsonnet"
  },
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
  },
  "[shellscript]": {
    "editor.defaultFormatter": "mkhl.shfmt"
  },
  "chat.tools.terminal.autoApprove": {
    "mkdir": true
  },
  "cSpell.customDictionaries": {
    "dotfiles": {
      "addWords": true,
      "description": "Words used in this project",
      "name": "dotfiles",
      "path": "${workspaceFolder:dotfiles}/.vscode/dictionary.txt",
      "scope": "workspace"
    }
  },
  "cSpell.enabled": true,
  "cSpell.language": "en-GB",
  "cSpell.validateDirectives": true,
  "deno.enable": false,
  "editor.allowVariableFontsInAccessibilityMode": false,
  "editor.codeLensFontFamily": "'Monaspace Argon ExtraLight'",
  "editor.defaultFormatter": "biomejs.biome",
  "editor.fontFamily": "Monaspace Argon ExtraLight, Fira Code, Monaco, monospace",
  "editor.fontLigatures": "'calt', 'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08', 'ss09', 'ss10', 'liga'",
  "editor.fontSize": 12,
  "editor.fontVariations": "'wght' 250",
  "editor.inlayHints.fontFamily": "'Monaspace Argon ExtraLight'",
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "comment",
        "settings": {
          "fontStyle": "italic"
        }
      },
      {
        "scope": "storage,entity,variable",
        "settings": {
          "fontStyle": ""
        }
      }
    ]
  },
  "evenBetterToml.formatter.trailingNewline": true,
  //"peacock.color": "#6272a4",
  "explorer.fileNesting.patterns": {
    "actions.sh": "actions.toml",
    "package.json": "lint-staged.config.*,.commitlintrc.*,.markdownlint.*,.npmrc.*,.nvmrc,.secretlint*,.shellcheck*,biome.*,.yamllint.*,.versionrc.*,eslint.*,jsconfig.*,tsconfig.*,link.config.*,package-lock.json, .fixpackrc, .editorconfig, .release-it.*, .npmrc, typos.toml,.mcp.json",
    "README.md": "SECURITY*, LICENSE*, CITATION.cff, OS_INSTALL_FIRST_STEPS.md, AGENTS.md,PROJECT.md"
  },
  "files.insertFinalNewline": true,
  "markdown.extension.toc.levels": "2..6",
  "terminal.integrated.fontFamily": "Monaspace Argon ExtraLight, Fira Code, Monaco, monospace",
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.fontLigatures.featureSettings": "'calt' on, 'liga' on, 'ss01' on, 'ss02' on, 'ss03' on, 'ss04' on, 'ss05' on, 'ss06' on, 'ss07' on, 'ss08' on, 'ss09' on, 'ss10' on",
  "terminal.integrated.fontWeight": 150,
  "terminal.integrated.fontWeightBold": 500,
  // https://code.visualstudio.com/api/references/theme-color
  "workbench.colorCustomizations": {
    "editorIndentGuide.activeBackground1": "#ff9900",
    "editorIndentGuide.background1": "#00000001",
    "activityBar.activeBackground": "#db9757",
    "activityBar.background": "#db9757",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#cbf4df",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#15202b99",
    "sash.hoverBorder": "#db9757",
    "statusBar.background": "#d27d2d",
    "statusBar.foreground": "#15202b",
    "statusBarItem.hoverBackground": "#a86424",
    "statusBarItem.remoteBackground": "#d27d2d",
    "statusBarItem.remoteForeground": "#15202b",
    "titleBar.activeBackground": "#d27d2d",
    "titleBar.activeForeground": "#15202b",
    "titleBar.inactiveBackground": "#d27d2d99",
    "titleBar.inactiveForeground": "#15202b99"
  },
  "yaml.validate": true,
  "markdownlint.configFile": "node_modules/@dnbhq/markdownlint-config/.markdownlint-cli2.jsonc",
  "peacock.color": "D27D2D"
}
