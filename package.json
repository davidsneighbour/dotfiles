    "debug": "4.4.3",
    "deepmerge": "4.3.1",
    "dotenv": "17.3.1",
    "fixpack": "4.0.0",
    "fs-extra": "11.3.4",
    "lint-staged": "16.4.0",
    "lockfile-lint": "5.0.0",
    "markdownlint": "0.40.0",
    "markdownlint-cli2": "0.22.0",
    "ncp": "2.0.0",
    "npm-check-updates": "19.6.6",
    "npm-package-json-lint": "9.1.0",
    "npm-run-all2": "8.0.4",
    "npm-watch": "0.13.0",
    "release-it": "19.2.4",
    "rimraf": "6.1.3",
    "secretlint": "11.4.0",
    "semver": "7.7.4",
    "simple-git-hooks": "2.13.1",
    "smol-toml": "1.6.1",
    "toml": "3.0.0",
    "wireit": "0.14.12"
  },
  "scripts": {
    "clean": "rimraf logs/*.log",
    "link:prepare": "wireit",
    "lint:config": "yamllint -c .yamllint.yml etc/*.yaml",
    "lint:hook:commit": "lint-staged --quiet",
    "lint:hook:commit:loud": "lint-staged --debug --verbose",
    "release": "release-it --config .release-it.ts --verbose --only-version"
  },
  "wireit": {
    "link:prepare": {
      "command": "npx link"
    }
  },
  "main": "index.js",
  "simple-git-hooks": {
    "pre-commit": "npm run lint:hook:commit"
  },
  "type": "module"
}
