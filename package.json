{
  "name": "@davidsneighbour/dotfiles",
  "description": "David's Neighbour's .dotfiles",
  "version": "3002.20.0",
  "license": "GPL-3.0-or-later",
  "repository": "https://github.com/davidsneighbour/dotfiles",
  "author": "Patrick Kollitsch <davidsneighbourdev+gh@gmail.com>",
  "bugs": "https://github.com/davidsneighbour/dotfiles/issues",
  "homepage": "https://github.com/davidsneighbour/dotfiles#readme",
  "dependencies": {
    "@biomejs/biome": "2.4.12",
    "@clack/prompts": "1.2.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@davidsneighbour/markdownlint-config": "2026.0.3",
    "@humanwhocodes/crosspost": "1.0.4",
    "@j9t/obsohtml": "1.9.5",
    "@release-it/conventional-changelog": "11.0.0",
    "@secretlint/secretlint-rule-no-dotenv": "12.2.0",
    "@secretlint/secretlint-rule-no-homedir": "12.2.0",
    "@secretlint/secretlint-rule-no-k8s-kind-secret": "12.2.0",
    "@secretlint/secretlint-rule-openai": "12.2.0",
    "@secretlint/secretlint-rule-pattern": "12.2.0",
    "@secretlint/secretlint-rule-preset-recommend": "12.2.0",
    "@secretlint/secretlint-rule-secp256k1-privatekey": "12.2.0",
    "cross-env": "10.1.0",
    "cspell": "10.0.0",
    "cz-git": "1.12.0",
    "debug": "4.4.3",
    "deepmerge": "4.3.1",
    "dotenv": "17.4.2",
    "fixpack": "4.0.0",
    "fs-extra": "11.3.4",
    "lint-staged": "16.4.0",
    "lockfile-lint": "5.0.0",
    "markdownlint": "0.40.0",
    "markdownlint-cli2": "0.22.1",
    "ncp": "2.0.0",
    "npm-check-updates": "21.0.3",
    "npm-package-json-lint": "10.2.1",
    "npm-run-all2": "8.0.4",
    "npm-watch": "0.13.0",
    "release-it": "20.0.1",
    "rimraf": "6.1.3",
    "secretlint": "12.2.0",
    "semver": "7.7.4",
    "simple-git-hooks": "2.13.1",
    "smol-toml": "1.6.1",
    "toml": "4.1.1",
    "wireit": "0.14.12"
  },
  "scripts": {
    "clean": "rimraf logs/*.log",
    "link:prepare": "wireit",
    "lint:config": "yamllint -c .yamllint.yml configs bashrc",
    "lint:hook:commit": "lint-staged --quiet",
    "lint:hook:commit:loud": "lint-staged --debug --verbose",
    "release": "release-it --config .release-it.ts --verbose --only-version"
  },
  "wireit": {
    "link:prepare": {
      "command": "npx link"
    }
  },
  "main": "index.js",
  "simple-git-hooks": {
    "pre-commit": "npm run lint:hook:commit"
  },
  "type": "module",
  "cspell": {
    "version": "0.2",
    "language": "en-GB",
    "ignorePaths": [
      ".vscode/dictionary.txt"
    ],
    "dictionaryDefinitions": [
      {
        "name": "custom",
        "path": ".vscode/dictionary.txt",
        "addWords": true
      }
    ],
    "dictionaries": [
      "custom"
    ]
  }
}
